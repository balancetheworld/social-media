{
  "name": "weiyan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"pnpm --filter web dev\" \"pnpm --filter servers dev\"",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter servers dev",
    "build": "pnpm --filter web build",
    "build:server": "pnpm --filter servers build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "overrides": {
      "is-generator-function": "1.0.10"
    }
  }
}
